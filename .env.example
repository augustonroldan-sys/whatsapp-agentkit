# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Evolution API (proveedor de WhatsApp) ─────────────────
# URL pública de tu instancia de Evolution API en Railway
EVOLUTION_URL=https://tu-evolution.railway.app
# Clave de autenticación (la que configuraste en Evolution)
EVOLUTION_API_KEY=
# Nombre de la instancia (la que creaste en Evolution)
EVOLUTION_INSTANCE=hefe

# ── Audio transcripción ───────────────────────────────────
# Groq (gratis, recomendado): https://console.groq.com
GROQ_API_KEY=
# OpenAI (alternativa): https://platform.openai.com
# OPENAI_API_KEY=

# ── Notificaciones Telegram ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production
# URL pública de Sofia (para configurar webhook en Evolution)
SERVER_URL=https://tu-sofia.railway.app

# ── CRM ───────────────────────────────────────────────────
CRM_PASSWORD=hefe2026

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
